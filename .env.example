# Desarrollo local (API en tu máquina o proxy de Vite en vite.config.ts)
VITE_BASE_URL_API=http://localhost:3000
VITE_MSW_ENABLED=true

# Producción en Netlify (configurar en Site settings → Environment variables):
# VITE_BASE_URL_API=          ← vacío o sin definir (peticiones a /api del mismo dominio)
# VITE_MSW_ENABLED=false
#
# El proxy /api → backend está en netlify.toml. Si cambias de servidor, actualiza la URL allí.
